# ═══════════════════════════════════════════════
# GUCPC Portal – Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════

# Django
SECRET_KEY=your-very-secret-key-change-this-in-production-use-50-random-chars
DEBUG=True

# Database (leave blank for SQLite locally)
DATABASE_URL=

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=GUCPC Exam Portal <your-gmail@gmail.com>
